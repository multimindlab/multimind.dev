---
import BaseLayout from "../layouts/BaseLayout.astro";
import Home from "../components/Home.astro";
import t from "../i18n/en";
import featuresByLocale from "../data/features";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "MultiMind SDK",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Cross-platform",
  description: "The compliance-first AI agent framework — one API for every LLM, with GDPR, HIPAA & EU AI Act evidence reporting built in.",
  url: "https://multimind.dev",
  softwareVersion: "latest",
  license: "https://github.com/multimindlab/multimind-sdk/blob/develop/LICENSE",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  author: { "@type": "Organization", name: "AI2Innovate", url: "https://ai2innovate.io" },
  codeRepository: "https://github.com/multimindlab/multimind-sdk",
  programmingLanguage: "Python",
};
---
<BaseLayout
  title="MultiMind SDK — The Compliance-First AI Agent Framework"
  description="One API for every LLM, with GDPR, HIPAA & EU AI Act support built in. Govern the AI stack you already have — LangChain, LlamaIndex, CrewAI — by changing one line."
  lang="en"
  nav={t.nav}
  footer={t.footer}
  translated={true}
  jsonLd={jsonLd}
>
  <Home t={t} features={featuresByLocale.en} />
</BaseLayout>
