---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  url: new URL(`/blog/${post.slug}`, Astro.site).toString(),
  author: { "@type": "Organization", name: "AI2Innovate", url: "https://ai2innovate.io" },
  publisher: { "@type": "Organization", name: "MultiMind SDK", url: "https://multimind.dev" },
  keywords: (post.data.tags || []).join(", "),
  inLanguage: "en",
};
---
<BaseLayout title={`${post.data.title} — MultiMind SDK`} description={post.data.description} jsonLd={jsonLd}>
  <section class="section">
    <div class="section-inner" style="max-width: 760px;">
      <p class="disclaimer reveal">
        {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </p>
      <h1 class="reveal">{post.data.title}</h1>
      <div class="reveal blog-post-body">
        <Content />
      </div>
      <p class="reveal"><a href="/blog">&larr; Back to blog</a></p>
    </div>
  </section>
</BaseLayout>
