---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<BaseLayout
  title="Blog — MultiMind SDK"
  description="AI adoption, MultiMind SDK internals, and running MultiMind across AWS, Azure, and GCP."
>
  <section class="section">
    <div class="section-inner">
      <h1 class="reveal">Blog</h1>
      <p class="section-lede reveal">AI adoption, MultiMind SDK internals, and cloud deployment notes.</p>

      <div class="grid grid-3" style="margin-top: 2rem;">
        {posts.map((post) => (
          <a class="card reveal" href={`/blog/${post.slug}`} style="text-decoration: none; color: inherit;">
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <p class="disclaimer">{post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
